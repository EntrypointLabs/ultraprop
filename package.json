{
  "name": "prop-firm",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "build": "turbo run build",
    "build:rust": "cargo build --workspace",
    "lint": "turbo run lint && biome check .",
    "test": "turbo run test && cargo test --workspace",
    "typecheck": "turbo run typecheck",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "turbo": "^2.9.14",
    "@biomejs/biome": "^2.4.15",
    "typescript": "^5.6.0"
  }
}
