{
  "name": "prop-firm",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "predev": "node scripts/predev.mjs",
    "dev": "node scripts/dev.mjs",
    "build": "turbo run build",
    "build:rust": "cargo build --workspace",
    "build:contracts": "node scripts/build-contracts.mjs",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint && biome check .",
    "test": "turbo run test && cargo test --workspace",
    "format": "biome format --write .",
    "check:toolchain": "node scripts/check-toolchain.mjs",
    "clean": "node scripts/clean.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "concurrently": "^9.1.0",
    "turbo": "^2.9.14",
    "typescript": "^5.6.0"
  }
}
