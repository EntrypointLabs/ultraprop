# Privy (auth)
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Optional: Privy access-token verification key (PEM). If unset, tokens are
# verified against Privy's JWKS automatically.
# PRIVY_VERIFICATION_KEY=

# Sui / propfirm package — public coordinates (safe to expose to the browser).
# These let the client read a trader's account directly from chain.
NEXT_PUBLIC_SUI_NETWORK=testnet
# Override the default fullnode RPC for the chosen network:
# NEXT_PUBLIC_SUI_RPC_URL=
NEXT_PUBLIC_PROPFIRM_PACKAGE_ID=
NEXT_PUBLIC_PROPFIRM_ACCOUNT_REGISTRY_ID=
NEXT_PUBLIC_PROPFIRM_ACCESS_REGISTRY_ID=
NEXT_PUBLIC_PROPFIRM_TREASURY_ID=
NEXT_PUBLIC_PROPFIRM_TIER_CONFIG_ID=
NEXT_PUBLIC_PROPFIRM_USDC_TYPE=
# Shared mock-USDC Faucet object id (testnet only). The user mints test USDC from
# it before paying their evaluation fee in the fee-first onboarding flow.
NEXT_PUBLIC_PROPFIRM_USDC_FAUCET_ID=
# Firm eval-funds destination address. The user transfers their fee here in the
# PAID path; the server verifies the payment landed on it before opening the
# account. Matches `evalFundsAddress` in deployments/testnet.json.
NEXT_PUBLIC_PROPFIRM_EVAL_FUNDS_ADDRESS=
# Tier opened for first-time traders: starter | basic | pro | elite | whale
NEXT_PUBLIC_PROPFIRM_DEFAULT_TIER=starter

# Firm admin + executor authority — SERVER ONLY. The firm signs and sponsors
# account creation (AdminCap-gated) and drives the evaluation lifecycle
# (ExecutorCap-gated: log_trade, pass/fail, register_dd_breach), so these must
# never be public. Bech32 (suiprivkey1...) or base64 Ed25519 secret for the firm
# signer; the deployer wallet holds both caps.
SUI_ADMIN_SECRET_KEY=
PROPFIRM_ADMIN_CAP_ID=
PROPFIRM_EXECUTOR_CAP_ID=

# Invite-code onboarding — SERVER ONLY. Comma-separated allowlist of codes that
# open a firm-funded Starter account with no payment. NOTE: codes are NOT single-
# use here (no durable consumption store in v1); the one-account-per-user check
# is the anti-abuse guard. Leave empty to disable the invite path.
PROPFIRM_INVITE_CODES=
