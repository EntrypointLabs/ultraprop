{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "docs/dist/**"],
      "env": [
        "PRIVY_APP_SECRET",
        "SUI_ADMIN_SECRET_KEY",
        "PROPFIRM_ADMIN_CAP_ID",
        "PROPFIRM_EXECUTOR_CAP_ID",
        "PROPFIRM_INVITE_CODES"
      ]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "test": {
      "dependsOn": ["build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    }
  }
}
