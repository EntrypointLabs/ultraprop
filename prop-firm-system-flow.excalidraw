    {
      "type": "text", "id": "offt2", "x": 634, "y": 262, "width": 252, "height": 216,
      "text": "CreateAccountFlow\nuseCreateAccount()\n  ↓\nPOST /api/account\n  ↓\nserver.openTradingAccount()\n(firm admin keypair signs,\npays eval fee in USDC)", "originalText": "CreateAccountFlow\nuseCreateAccount()\n  ↓\nPOST /api/account\n  ↓\nserver.openTradingAccount()\n(firm admin keypair signs,\npays eval fee in USDC)",
