    {
      "type": "text", "id": "oct5", "x": 1594, "y": 592, "width": 252, "height": 216,
      "text": "user_account::log_trade\n (ExecutorCap)\n  ↓\non-chain risk gates →\nSuspended on\ndaily-loss / max-DD breach\n\n[v2 · executor-driven]", "originalText": "user_account::log_trade\n (ExecutorCap)\n  ↓\non-chain risk gates →\nSuspended on\ndaily-loss / max-DD breach\n\n[v2 · executor-driven]",
