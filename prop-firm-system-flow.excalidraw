    {
      "type": "text", "id": "oct4", "x": 1274, "y": 592, "width": 252, "height": 216,
      "text": "v2 design: an executor\nwould route fills on-chain\n\n— NOT wired —\nto the paper sim engine", "originalText": "v2 design: an executor\nwould route fills on-chain\n\n— NOT wired —\nto the paper sim engine",
